# Token del bot de Discord (https://discord.com/developers/applications)
DISCORD_TOKEN=

# ID del canal donde el bot escucha /buscar (click derecho sobre el canal -> Copy Channel ID)
ALLOWED_CHANNEL_ID=

# URL base de Prowlarr (sin barra final). Ej: http://prowlarr:9696 si esta en la misma red docker
PROWLARR_URL=http://prowlarr:9696

# API Key de Prowlarr (Settings -> General -> Security -> API Key)
PROWLARR_API_KEY=

# Opcional: timeout en segundos para consultas a Prowlarr. Default: 90
PROWLARR_TIMEOUT=90

# Opcional: si vale true, intenta adjuntar el .torrent junto al magnet cuando Prowlarr lo pueda descargar
ATTACH_TORRENT_FILE=false

# Opcional: host/puerto donde escucha el mini servidor HTTP del bot
BOT_HTTP_LISTEN_HOST=0.0.0.0
BOT_HTTP_LISTEN_PORT=9987

# Opcional: URL publica base para los links clickeables que se mandan a Discord. Sin / al final.
# Si usas nginx en el host, puedes dejar el contenedor publicado solo en 127.0.0.1:19987
# y mantener esta URL publica apuntando a http://errete.ddns.net:9987.
BOT_PUBLIC_BASE_URL=http://errete.ddns.net:9987

# Opcional: timeout para resolver metadata via DHT cuando solo hay magnet. Default: 45
TORRENT_FETCH_TIMEOUT=45

# Opcional: puerto que usa libtorrent para DHT. Default: 6881
LIBTORRENT_LISTEN_PORT=6881

# Opcional: nivel de log (DEBUG, INFO, WARNING, ERROR). Default: INFO
LOG_LEVEL=INFO

# Opcional: tiempo de vida en segundos de los links /m/<id> y /t/<id> y del mensaje de Discord asociado.
# Default: 604800 (7 dias). Al vencer se borra el archivo del registry y se intenta borrar el mensaje.
REGISTRY_TTL_SECONDS=604800

# Opcional: intervalo en segundos del purge que limpia entradas vencidas. Default: 300 (5 min)
REGISTRY_PURGE_INTERVAL_SECONDS=300

# Opcional: directorio donde se persisten las entradas del registry. Default: /app/data/registry
REGISTRY_DATA_DIR=/app/data/registry

# Opcional: rate limit de /buscar por usuario. Default: 5 llamadas cada 60s
RATE_LIMIT_CALLS=5
RATE_LIMIT_WINDOW_SECONDS=60
